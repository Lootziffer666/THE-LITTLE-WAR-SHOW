{
  "name": "the-little-war-show-theater",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "The Theater — a WebGPU/TSL diorama for The Little War Show. Hearthstone/Wayfinder-styled, volumetric, lived-in.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "preview": "vite preview --port 4173"
  },
  "dependencies": {
    "@react-spring/three": "10.1.1",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@rive-app/canvas": "2.38.1",
    "pixi.js": "8.19.0",
    "react": ">=19.0.0 <19.3.0",
    "react-dom": ">=19.0.0 <19.3.0",
    "three": "0.184.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  }
}
